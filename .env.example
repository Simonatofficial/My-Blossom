# Copy this file to ".env" and paste your real values. NEVER commit ".env".
#
# To ACTIVATE cloud sync: paste the Supabase Project URL + anon key here (or into
# app.json -> expo.extra). The anon key is the public client key — safe in the
# app. Then run supabase/schema.sql and enable the Anonymous / Email / Google
# auth providers in the Supabase dashboard. With these empty the app runs fully
# offline (no sync, no crash). Only the ANON key ever belongs on the client.

# Supabase (Project Settings -> API)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# RevenueCat (public SDK keys; safe in the app)
REVENUECAT_API_KEY_ANDROID=
REVENUECAT_API_KEY_IOS=

# Stripe (WEB build only — use the PUBLISHABLE key; secret key stays server-side)
STRIPE_PUBLISHABLE_KEY=
