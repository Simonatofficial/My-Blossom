{
  "expo": {
    "name": "My Blossom",
    "slug": "my-blossom",
    "owner": "my-blossom",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "myblossom",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.simon.myblossom",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "ios": {
      "bundleIdentifier": "com.simon.myblossom",
      "buildNumber": "1",
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-notifications",
      "expo-background-task",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supabaseUrl": "",
      "supabaseAnonKey": "",
      "router": {},
      "eas": {
        "projectId": "29f8efea-b9b2-4a64-9476-6a795bbbd07e"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/29f8efea-b9b2-4a64-9476-6a795bbbd07e"
    }
  }
}
